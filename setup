#!/bin/bash

# Set up XDG_CONFIG_HOME
export XDG_CONFIG_HOME="$HOME"/.config
mkdir -p "$XDG_CONFIG_HOME"

# Create symlinks for existing configurations
ln -sf "$PWD/nvim" "$XDG_CONFIG_HOME"/nvim
ln -sf "$PWD/.tmux.conf" "$HOME"/.tmux.conf

# Fetch and set up Zsh configuration files from my main dotfiles repo
curl -o "$HOME/.zshrc" https://raw.githubusercontent.com/pedrotchang/dotfiles/main/.zshrc
curl -o "$HOME/.zprofile" https://raw.githubusercontent.com/pedrotchang/dotfiles/main/.zprofile

packages=(
  fd-find
  ripgrep
  npm
  lazygit
  fzf
  kubectl
  fluxcd
  k9s
  kubectx
  direnv
  kubectl-cnpg
)

# Update package list
sudo apt-get update

# Iterate over the array and install each package
for package in "${packages[@]}"; do
  echo "Installing $package..."
  
  case "$package" in
    "fluxcd")
      # Install FluxCD
      curl -s https://fluxcd.io/install.sh | sudo bash
      ;;
    "lazygit")
      # Install LazyGit
      sudo apt install -y lazygit
      ;;
    "k9s")
      # Install K9s
      curl -s https://github.com/derailed/k9s/releases/download/v0.32.7/k9s_Linux_arm64.tar.gz | tar xz -C /usr/local/bin
      ;;
    "kubectx")
      # Install kubectx
      curl -s https://github.com/ahmetb/kubectx/releases/download/v0.9.3/kubectx-linux-amd64 -o /usr/local/bin/kubectx && chmod +x /usr/local/bin/kubectx
      ;;
    "kubectl-cnpg")
      # Assuming this is a custom package
      echo "Please install kubectl-cnpg manually from its official source."
      ;;
    *)
      sudo apt-get install -y "$package"
      ;;
  esac
done

# Set up pure prompt

mkdir -p "$HOME/.zsh"
git clone https://github.com/sindresorhus/pure.git "$HOME/.zsh/pure"

# Silence source warning

touch "$HOME/.privaterc"

# Set up completions

mkdir -p "$HOME/.zfunc"
flux completion zsh > "$HOME/.zfunc/_flux"
kubectl completion zsh > "$HOME/.zfunc/_kubectl"
helm completion zsh > "$HOME/.zfunc/_helm"

echo "Setup complete. Zsh configuration files have been downloaded and set up."
